{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://careloop.example/contracts/atlas-task-request/1.0",
  "title": "Atlas Task Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "taskId", "incidentId", "chairId", "capability", "priority", "parameters", "requestedEvidence", "requestedBy"],
  "properties": {
    "contractVersion": { "type": "string", "const": "1.0" },
    "taskId": { "type": "string", "pattern": "^task-[a-z0-9-]+$" },
    "incidentId": { "type": "string", "pattern": "^incident-[a-z0-9-]+$" },
    "chairId": { "type": "string", "enum": ["chair-01", "chair-02", "chair-03", "chair-04"] },
    "capability": { "type": "string", "enum": ["deliver_item", "collect_vital_sign", "observe_patient", "ask_patient"] },
    "priority": { "type": "string", "enum": ["routine", "urgent"] },
    "requestedBy": { "type": "string", "const": "mira" },
    "requestedEvidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
    "contextText": { "type": "string", "maxLength": 500 },
    "parameters": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "capability": { "const": "deliver_item" } }, "required": ["capability"] },
      "then": {
        "properties": {
          "parameters": {
            "type": "object",
            "additionalProperties": false,
            "required": ["item", "preApproved"],
            "properties": {
              "item": { "type": "string", "enum": ["water", "coffee", "blanket"] },
              "preApproved": { "type": "boolean", "const": true }
            }
          }
        }
      }
    }
  ]
}
