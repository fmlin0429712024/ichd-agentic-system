{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://careloop.example/schemas/body-mission.schema.json",
  "title": "CareLoop Body Mission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "missionId",
    "taskId",
    "incidentId",
    "capability",
    "pickup",
    "destination",
    "createdAt"
  ],
  "properties": {
    "contractVersion": { "const": "1.0" },
    "missionId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "taskId": { "type": "string", "minLength": 3, "maxLength": 80 },
    "incidentId": { "type": "string", "minLength": 3, "maxLength": 80 },
    "capability": { "const": "deliver_item" },
    "pickup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locationId", "payload"],
      "properties": {
        "locationId": { "const": "operations-hub" },
        "payload": { "type": "string", "minLength": 1, "maxLength": 40 }
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locationId"],
      "properties": {
        "locationId": {
          "enum": ["chair-01", "chair-02", "chair-03", "chair-04"]
        }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
